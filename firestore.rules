rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'displayName', 'email', 'companyName', 'phoneNumber', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
             data.displayName is string && data.displayName.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.companyName is string && data.companyName.size() <= 200 &&
             data.phoneNumber is string && data.phoneNumber.size() <= 50 &&
             data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) &&
                    incoming().userId == existing().userId && incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'companyName', 'phoneNumber']);
      
      match /testResults/{resultId} {
        allow read, list, create, delete: if isSignedIn() && request.auth.uid == userId;
      }
    }
  }
}
